# ── Required ──────────────────────────────────────────────────────────────────

# Flask environment (set to 'production' on Railway)
FLASK_ENV=production

# Strong random string — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me

# PostgreSQL connection string — provided automatically by Railway Postgres plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Email (Resend) ─────────────────────────────────────────────────────────────

# API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Verified sender address (domain must be verified in Resend) — used for transactional emails (password reset etc.)
MAIL_FROM=Dogboxx <noreply@dogboxx.org>

# Optional: separate verified sender for newsletter emails. Falls back to MAIL_FROM if not set.
# NEWSLETTER_MAIL_FROM=Lydia <lydia@dogboxx.org>

# Public base URL of the app — used in password reset links
APP_BASE_URL=https://your-app.up.railway.app

# ── Optional ───────────────────────────────────────────────────────────────────

# Redis URL for persistent rate limiting (Railway Redis plugin)
# Falls back to in-memory if not set — fine for single worker
# REDIS_URL=redis://default:password@host:6379
