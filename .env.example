# ── Required ──────────────────────────────────────────────────────────────────

# Flask environment (set to 'production' on Railway)
FLASK_ENV=production

# Strong random string — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me

# PostgreSQL connection string — provided automatically by Railway Postgres plugin.
# Local dev: point at a Postgres you provision yourself, e.g.
#   postgresql://dogboxx:your-dev-password@localhost:5432/dogboxx
# (see README "Set up PostgreSQL" for the from-scratch sequence). Omit entirely to
# fall back to sqlite:///app.db for a quick start.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Email (Resend) ─────────────────────────────────────────────────────────────

# API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Verified sender for transactional emails clients shouldn't reply to (password reset, bug report).
MAIL_NO_REPLY=DogBoxx <noreply@dogboxx.org>

# Verified sender for client-facing emails clients can reply to (newsletter, broadcasts).
# Falls back to MAIL_NO_REPLY (with a warning logged) if unset.
MAIL_REPLY=Lydia <lydia@dogboxx.org>

# Recipient for bug reports submitted via the in-app bug report form.
BUG_REPORTS=you@example.com

# Public base URL of the app — used in password reset links
APP_BASE_URL=https://your-app.up.railway.app

# ── Optional ───────────────────────────────────────────────────────────────────

# Redis URL for persistent rate limiting (Railway Redis plugin)
# Falls back to in-memory if not set — fine for single worker
# REDIS_URL=redis://default:password@host:6379

# Test database for `pytest` (local dev only — read by TestingConfig).
# Point at a SEPARATE dogboxx_test DB on your existing dev Postgres, reusing
# your dev creds. Tests create/drop their own tables here; the dev DB is never
# touched. One-time: `createdb -O dogboxx dogboxx_test`.
# Unset -> falls back to CI creds (fails to auth locally). USE_SQLITE=1 -> SQLite.
# TEST_DATABASE_URL=postgresql://dogboxx:your-dev-password@localhost:5432/dogboxx_test
