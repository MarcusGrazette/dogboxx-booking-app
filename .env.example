# ── Required ──────────────────────────────────────────────────────────────────

# Flask environment (set to 'production' on Railway)
FLASK_ENV=production

# Strong random string — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me

# PostgreSQL connection string — provided automatically by Railway Postgres plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Email (Resend) ─────────────────────────────────────────────────────────────

# API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Verified sender for transactional emails clients shouldn't reply to (password reset, bug report).
MAIL_NO_REPLY=DogBoxx <noreply@dogboxx.org>

# Verified sender for client-facing emails clients can reply to (newsletter, broadcasts).
# Falls back to MAIL_NO_REPLY (with a warning logged) if unset.
MAIL_REPLY=Lydia <lydia@dogboxx.org>

# Public base URL of the app — used in password reset links
APP_BASE_URL=https://your-app.up.railway.app

# ── Optional ───────────────────────────────────────────────────────────────────

# Redis URL for persistent rate limiting (Railway Redis plugin)
# Falls back to in-memory if not set — fine for single worker
# REDIS_URL=redis://default:password@host:6379
